# PPAGLA Photo Judging — Environment Variables
# Copy this file to .env and fill in the values.
# On Vercel, set these in Project Settings → Environment Variables.

# Published CSV URL of the Credentials Google Sheet
# How to get this:
#   1. Open the Google Sheet with judge credentials
#   2. File → Share → Publish to web
#   3. Select the "Credentials" sheet → CSV format → Publish
#   4. Copy the URL
VITE_CREDENTIALS_SHEET_URL=

# Google Apps Script web app deployment URL
# How to get this:
#   1. Open the Google Sheet → Extensions → Apps Script
#   2. Deploy → Manage deployments
#   3. Copy the Web app URL
VITE_APPS_SCRIPT_URL=
